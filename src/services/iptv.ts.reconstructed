export function getFormatBadge(ext?: string): string | null {
  const e = normalizeExt(ext);
  if (e === "m3u8") return "HLS";
  if (e === "mp4") return "MP4";
  return null;
}

export function getStreamType(url: string): "live" | "vod" {
