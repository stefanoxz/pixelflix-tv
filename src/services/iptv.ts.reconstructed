export async function iptvFetch(creds: IptvCredentials, action: string, params: Record<string, any> = {}): Promise<any> {
  const url = `${creds.streamBase}/player_api.php?username=${creds.username}&password=${creds.password}&action=${action}`;
  const response = await fetch(url);
  if (!response.ok) throw new Error("Falha na requisição ao servidor");
  return await response.json();
}

export function proxyImageUrl(url: string, opts?: { w?: number; h?: number; q?: number }): string {
  if (!url) return "";
  return url;
}

export async function requestStreamToken(opts: { url?: string | null; kind: string; iptvUsername?: string; mode: string }): Promise<{ url: string }> {
  const { data, error } = await supabase.functions.invoke("stream-token", {
    body: { url: opts.url, kind: opts.kind, mode: opts.mode },
  });
  if (error || !data?.url) throw new Error("Falha ao obter token de stream");
  return { url: data.url };
}

export async function reportStreamEvent(type: string, meta: any) {
  await supabase.functions.invoke("stream-proxy", {
    body: { mode: "log", type, ...meta },
  }).catch(() => {});
}

export function getPlaybackStrategy(ext?: string, url?: string): { mode: "internal" | "external" | "error"; reason?: string; type?: "hls" | "native" } {
  const e = (ext || "").toLowerCase().replace(/^\./, "");
  if (["m3u8", "ts"].includes(e)) return { mode: "internal", type: "hls" };
  if (["mp4", "mkv", "avi", "mov", "webm"].includes(e)) return { mode: "internal", type: "native" };
  return { mode: "external", reason: "Formato não suportado" };
}

export function isValidStreamUrl(url: string): boolean {
  return /^https?:\/\//i.test(url);
}

export function normalizeExt(ext?: string): string {
  return ext ? ext.replace(/^\./, "").toLowerCase() : "";
}

export function getHostProxyMode(url?: string | null): "redirect" | "stream" {
