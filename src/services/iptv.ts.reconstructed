export async function iptvLogin(creds: IptvCredentials): Promise<LoginResponse> {
  const { data, error } = await supabase.functions.invoke("iptv-login", {
    body: { server: creds.server, username: creds.username, password: creds.password },
  });
  if (error || !data?.success) {
    throw new Error(data?.error || "Falha ao conectar ao servidor");
  }
  return data;
}

export async function iptvLoginM3u(creds: IptvCredentials): Promise<LoginResponse & { auto_registered?: boolean }> {
  const { data, error } = await supabase.functions.invoke("iptv-login", {
    body: { mode: "m3u_register", server: creds.server, username: creds.username, password: creds.password },
  });
  if (error || !data?.success) {
    throw new Error(data?.error || "Falha ao processar URL M3U");
  }
  return data;
}

export async function fetchAllowedServers(): Promise<string[]> {
  const { data, error } = await supabase.functions.invoke("iptv-login", {
    body: { mode: "validate" },
  });
  if (error || !data?.allowed) return [];
  return data.candidates || [];
}

export function isHostAllowed(host: string, allowed: string[]): boolean {
  const normalized = host.toLowerCase().replace(/^https?:\/\//, "").replace(/\/+$/, "");
  return allowed.some((a) => a.toLowerCase().includes(normalized));
}

export function resolveStreamBase(serverInfo: ServerInfo, serverUrl: string, allowed?: string[]): string {
  return serverUrl.replace(/\/+$/, "");
}

